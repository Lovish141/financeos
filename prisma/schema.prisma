generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                    String       @id @default(cuid())
  name                  String
  isDemo                Boolean      @default(false)
  baseCurrency          String       @default("INR")
  weightUnit            String       @default("kg")
  marginRedThreshold    Float        @default(15)
  marginYellowThreshold Float        @default(30)
  marginGoalPct         Float        @default(55)
  stalenessDays         Int          @default(30)
  simSettings           Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  customers             Customer[]
  masterCosts           MasterCost[]
  products              Product[]
  sales                 Sale[]
  templates             Template[]
  users                 User[]
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  passwordHash  String?
  role          Role          @default(VIEWER)
  emailVerified DateTime?
  image         String?
  companyId     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  costChanges   CostHistory[] @relation("CostChangedBy")
  sessions      Session[]
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model MasterCost {
  id               String              @id @default(cuid())
  companyId        String
  name             String
  category         String?
  type             CostType
  unit             String
  currentCost      Float
  archived         Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  history          CostHistory[]
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  usedInComponents TemplateComponent[]

  @@index([companyId, type])
  @@index([companyId, archived])
}

model CostHistory {
  id           String     @id @default(cuid())
  masterCostId String
  oldValue     Float?
  newValue     Float
  changedById  String?
  createdAt    DateTime   @default(now())
  changedBy    User?      @relation("CostChangedBy", fields: [changedById], references: [id])
  masterCost   MasterCost @relation(fields: [masterCostId], references: [id], onDelete: Cascade)

  @@index([masterCostId, createdAt])
}

model Template {
  id         String              @id @default(cuid())
  companyId  String
  name       String
  category   String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  products   Product[]
  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  components TemplateComponent[]
  versions   TemplateVersion[]

  @@index([companyId])
}

model TemplateComponent {
  id           String     @id @default(cuid())
  templateId   String
  masterCostId String
  lineType     LineType
  quantity     Float?
  sortOrder    Int        @default(0)
  masterCost   MasterCost @relation(fields: [masterCostId], references: [id])
  template     Template   @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([masterCostId])
}

model TemplateVersion {
  id         String    @id @default(cuid())
  templateId String
  version    Int
  snapshot   Json
  createdAt  DateTime  @default(now())
  products   Product[]
  template   Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId])
}

model Product {
  id                String           @id @default(cuid())
  companyId         String
  name              String
  sku               String
  templateId        String?
  templateVersionId String?
  sellingPrice      Float
  status            ProductStatus    @default(ACTIVE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  comps             Json?
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template          Template?        @relation(fields: [templateId], references: [id], onDelete: Restrict)
  templateVersion   TemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  sales             Sale[]

  @@unique([companyId, sku])
  @@index([companyId, templateId])
}

model Sale {
  id         String        @id @default(cuid())
  companyId  String
  productId  String
  customerId String?
  quantity   Float
  unitPrice  Float
  soldAt     DateTime
  channel    SalesChannel?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([companyId, soldAt])
  @@index([companyId, productId])
  @@index([productId])
  @@index([customerId])
}

model Customer {
  id        String        @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  channel   SalesChannel?
  gstin     String?
  city      String?
  notes     String?
  archived  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales     Sale[]

  @@index([companyId, archived])
}

enum Role {
  ADMIN
  COST_MANAGER
  VIEWER
}

enum CostType {
  RAW_MATERIAL
  COMPONENT
  SERVICE
}

enum LineType {
  WEIGHT
  FIXED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  DISCONTINUED
}

enum SalesChannel {
  RETAIL
  WHOLESALE
  DISTRIBUTOR
  EXPORT
  ONLINE
  OTHER
}
