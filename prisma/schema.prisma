// FinanceOS — Prisma schema
// Manufacturing profitability & costing platform.
// Hierarchy: MasterCost (price book) -> Template (BOM) -> Product (SKU).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Neon: pooled connection string for the app runtime …
  url       = env("DATABASE_URL")
  // … and a direct (non-pooled) connection for migrations. On Neon this is the
  // same host with `-pooler` removed from the hostname.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Module 7 — Multi-tenancy, Auth & Permissions
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  COST_MANAGER
  VIEWER
  // External buyer (wholesaler / dealer / retailer) who signs in to the buyer
  // portal to raise order requests. Scoped to the manufacturer's tenant like
  // any User, but additionally linked to the Customer org they represent.
  BUYER
}

model Company {
  id       String @id @default(cuid())
  name     String
  isDemo   Boolean @default(false)

  // Org settings (Module 7)
  baseCurrency String @default("INR")
  weightUnit   String @default("kg")

  // Margin health thresholds, % (Module 3 / 4) — company configurable.
  marginRedThreshold    Float @default(15) // below this => red
  marginYellowThreshold Float @default(30) // below this => yellow, else green

  // Target gross-margin goal, % — the benchmark the dashboard compares the
  // portfolio average against ("… vs goal"). Company configurable.
  marginGoalPct Float @default(55)

  // Staleness flag for price book (Module 1), in days.
  stalenessDays Int @default(30)

  // Persisted what-if simulation setup (Module 5) — the master-cost items the
  // user last chose to include in the simulator, so it reopens with their preset.
  // Shape: string[] of masterCostIds. Values are never saved (always start from
  // each item's live base). Null => no saved preset.
  simSettings Json?

  users        User[]
  masterCosts  MasterCost[]
  templates    Template[]
  products     Product[]
  customers    Customer[]
  orders       Order[]
  sales        Sale[]
  orderRequests OrderRequest[]
  portalInvites PortalInvite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String?
  role         Role      @default(VIEWER)
  emailVerified DateTime?
  image        String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // BUYER users only — the Customer org this login acts on behalf of. Null for
  // staff (ADMIN / COST_MANAGER / VIEWER).
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  accounts Account[]
  sessions Session[]

  costChanges    CostHistory[]    @relation("CostChangedBy")
  productChanges ProductHistory[] @relation("ProductChangedBy")

  // Order-request activity (Module — Buyer Portal).
  requestsCreated OrderRequest[] @relation("RequestCreatedBy")
  requestsDecided OrderRequest[] @relation("RequestDecidedBy")
  invitesSent     PortalInvite[] @relation("InviteInvitedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([customerId])
}

// --- Auth.js (NextAuth v5) adapter models. Database sessions (not JWT). ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Module 1 — Master Costs (Price Book)
// ---------------------------------------------------------------------------

enum CostType {
  RAW_MATERIAL // priced by weight, e.g. ₹/kg
  COMPONENT    // priced per piece
  SERVICE      // priced per piece / per unit of work
}

model MasterCost {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  category    String?
  type        CostType
  unit        String   // "kg", "piece", etc.
  currentCost Float

  archived    Boolean  @default(false)

  history          CostHistory[]
  usedInComponents TemplateComponent[]
  // COST_* product revisions this cost triggered (reprice / archive / restore).
  productRevisions ProductHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // doubles as "last price update" for staleness

  @@index([companyId, type])
  @@index([companyId, archived])
}

// Append-only price history — one row per cost change (Module 1 acceptance).
model CostHistory {
  id           String   @id @default(cuid())
  masterCostId String
  masterCost   MasterCost @relation(fields: [masterCostId], references: [id], onDelete: Cascade)

  oldValue     Float?
  newValue     Float

  changedById  String?
  changedBy    User?    @relation("CostChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  // COST_REPRICED product revisions caused by this exact price change.
  productRevisions ProductHistory[]

  createdAt    DateTime @default(now())

  @@index([masterCostId, createdAt])
}

// ---------------------------------------------------------------------------
// Module 2 — Templates (BOM / Recipe Builder)
// ---------------------------------------------------------------------------

model Template {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name     String
  category String?

  components TemplateComponent[]
  versions   TemplateVersion[]
  products   Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

enum LineType {
  WEIGHT // one raw material applied by weight; quantity supplied per-product
  FIXED  // component/service at a fixed quantity
}

// The current, editable recipe lines for a template.
model TemplateComponent {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  masterCostId String
  masterCost   MasterCost @relation(fields: [masterCostId], references: [id], onDelete: Restrict)

  lineType LineType
  quantity Float?   // null/unused for WEIGHT lines (weight supplied per-product)

  sortOrder Int @default(0)

  @@index([templateId])
  @@index([masterCostId]) // fan-out query for simulation (Module 5)
}

// Immutable snapshot of a template at save time. Products pin to a version so
// historical product costs don't drift when the live template is edited.
model TemplateVersion {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  version  Int
  // Structure-only snapshot (Live Reference Architecture): IDs + quantities, no
  // master-cost field copies. Kept for provenance/history; costs resolve live.
  // { version, templateName, category, lines: [{ masterCostId, lineType, quantity }] }
  snapshot Json

  products Product[]

  createdAt DateTime @default(now())

  @@unique([templateId, version])
  @@index([templateId])
}

// ---------------------------------------------------------------------------
// Module 3 — Products (SKUs)
// ---------------------------------------------------------------------------

enum ProductStatus {
  DRAFT
  ACTIVE
  DISCONTINUED
}

model Product {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name String
  sku  String

  // Human-facing catalogue identifiers (optional). productCode is a short
  // reference/part number; seriesName groups SKUs into a product line/range.
  productCode String?
  seriesName  String?

  // Optional so a product can be built from an "Empty Template" (no base recipe).
  templateId        String?
  template          Template?        @relation(fields: [templateId], references: [id], onDelete: Restrict)
  templateVersionId String?
  templateVersion   TemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)

  // Per-product effective component list — slim, IDs only (Live Reference
  // Architecture): [{ masterCostId, lineType, quantity }]. This is the product's
  // own recipe, which insulates it from template edits; every field (name/unit/
  // cost) resolves live from MasterCost at read time. Null => inherit the pinned
  // templateVersion snapshot (legacy products).
  comps Json?

  // Reality supplied at the SKU level (Module 3). Per-line quantities — raw
  // materials by weight included — live on each line in `comps`.
  sellingPrice Float

  // No cached cost/margin columns — cost & margin are computed on read from the
  // live price book everywhere they're shown (Live Reference Architecture).

  status ProductStatus @default(ACTIVE)

  history ProductHistory[]
  sales   Sale[]
  requestItems OrderRequestItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, sku])
  @@index([companyId, templateId])
}

// What triggered a ProductHistory row. Metadata events come from editing the
// product itself; COST_* events fan out when a referenced master cost moves the
// product's computed cost.
enum ProductHistoryKind {
  CREATED       // product first saved
  METADATA      // product's own fields edited (name / status / price / recipe)
  COST_REPRICED // a referenced master cost's price changed
  COST_ARCHIVED // a referenced master cost was archived (line drops from total)
  COST_RESTORED // a referenced master cost was restored (line re-enters total)
}

// Append-only revision log for a product. One row per event that changed the
// product (create / metadata edit) or moved its computed cost (a referenced
// master cost repriced / archived / restored, fanned out to each affected SKU).
// Each row is a SELF-CONTAINED snapshot — the product's fields + recipe + the
// cost resolved at that instant — so reading the timeline never needs a join.
// The stored cost is a point-in-time record, NOT a live cache: current cost is
// still computed on read (Live Reference Architecture). Reached through the
// tenant-scoped Product (no own companyId), mirroring CostHistory.
model ProductHistory {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  kind ProductHistoryKind

  // Product field snapshot as of this instant.
  name         String
  sku          String
  productCode  String?
  seriesName   String?
  status       ProductStatus
  sellingPrice Float
  comps        Json? // recipe as saved (slim: [{ masterCostId, lineType, quantity }])

  // Cost resolved at this instant (point-in-time record, not a live cache).
  totalCost      Float
  grossMarginPct Float
  // Resolved per-line breakdown as of this instant, so the revision detail view
  // renders faithfully without a join (component name/unit/qty/unitCost/lineCost).
  // Shape: [{ masterCostId, name, unit, quantity, unitCost, lineCost, needsAttention }].
  lines          Json?

  // The actor who caused it (null once the user is deleted).
  changedById String?
  changedBy   User?   @relation("ProductChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  // COST_* rows: which master cost moved. COST_REPRICED also links the exact
  // CostHistory row so the price-book log and the product log cross-reference.
  triggerMasterCostId String?
  triggerMasterCost   MasterCost?  @relation(fields: [triggerMasterCostId], references: [id], onDelete: SetNull)
  costHistoryId       String?
  costHistory         CostHistory? @relation(fields: [costHistoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([productId, createdAt])
  @@index([triggerMasterCostId])
}

// ---------------------------------------------------------------------------
// Module — Sales & Customers
// ---------------------------------------------------------------------------

enum SalesChannel {
  RETAIL
  WHOLESALE
  DISTRIBUTOR
  EXPORT
  ONLINE
  OTHER
}

// How a discount value is interpreted: a percentage of the base, or a flat
// currency amount off it. Used by both line-item and order-level discounts.
enum DiscountType {
  PERCENT
  FLAT
}

// A sale order (invoice) — the real-world unit of a sale, booked against one
// customer on one date/channel. Holds one or more product line items (Sale).
model Order {
  id         String        @id @default(cuid())
  companyId  String
  customerId String?
  soldAt     DateTime
  channel    SalesChannel?
  // Invoice-wide discount applied on top of any per-line discounts (e.g. a bulk
  // or loyalty deal). Stored separately from line discounts so both coexist.
  discountType  DiscountType?
  discountValue Float         @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items      Sale[]
  // The buyer order request this sale was booked from, if any (Buyer Portal).
  request    OrderRequest?

  @@index([companyId, soldAt])
  @@index([customerId])
}

// One product line within an Order — the atomic unit all per-product margin and
// profit analytics aggregate over. Shared fields (customer/date/channel) live on
// the parent Order.
model Sale {
  id        String   @id @default(cuid())
  companyId String
  orderId   String
  productId String
  quantity  Float
  // List (catalogue) unit price — the price before any discount. The realized net
  // price is unitPrice minus the line discount (see src/lib/discount.ts).
  unitPrice Float
  // Per-line negotiated/promotional discount off the unit price. type null +
  // value 0 => no line discount.
  discountType  DiscountType?
  discountValue Float         @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([orderId])
  @@index([productId])
}

model Customer {
  id        String        @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  channel   SalesChannel?
  gstin     String?
  city      String?
  notes     String?
  archived  Boolean       @default(false)

  // Standing discount % this customer has negotiated — pre-fills the order-level
  // discount on a New Sale (still editable per sale). Null => none.
  defaultDiscountPct Float?

  // Buyer-portal access (Module — Buyer Portal). When true, staff have granted
  // this customer login access; buyer Users and invites hang off it.
  portalEnabled Boolean @default(false)

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders    Order[]

  buyerUsers User[]
  requests   OrderRequest[]
  invites    PortalInvite[]

  @@index([companyId, archived])
}

// ---------------------------------------------------------------------------
// Module — Buyer Portal (order requests & approval)
// ---------------------------------------------------------------------------

// A buyer's order request travels through this staging lineage, kept entirely
// separate from Sale so realized-sales analytics never see un-booked requests.
// On approval the request materializes into an Order + its Sale line items.
enum OrderRequestStatus {
  DRAFT             // buyer is building the cart (not yet raised)
  SUBMITTED         // raised by the buyer, awaiting staff
  UNDER_REVIEW      // a staff member has opened it
  CHANGES_REQUESTED // sent back to the buyer to amend & resubmit
  APPROVED          // terminal — booked an Order
  REJECTED          // terminal — declined
  CANCELLED         // terminal — withdrawn by the buyer
}

model OrderRequest {
  id         String  @id @default(cuid())
  companyId  String
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // The buyer User who raised it (kept even if the user is later removed).
  createdById String?
  createdBy   User?   @relation("RequestCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  status     OrderRequestStatus @default(DRAFT)
  buyerNote  String?  // optional message from the buyer with the request
  reviewNote String?  // staff message on reject / changes-requested

  submittedAt DateTime?
  decidedAt   DateTime?
  decidedById String?
  decidedBy   User?    @relation("RequestDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  // The booked sale produced on approval (one-to-one).
  orderId String? @unique
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  items OrderRequestItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([customerId])
}

// One product line on an order request. Carries BOTH the buyer's requested
// values and the staff-approved values, so an approved-with-changes request
// renders a faithful requested→approved diff without touching Sale.
model OrderRequestItem {
  id        String @id @default(cuid())
  requestId String
  request   OrderRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  // What the buyer asked for. Null when staff ADDED this line at approval.
  requestedQty       Float?
  requestedUnitPrice Float? // catalog sellingPrice snapshot at request time

  // What staff approved. Set at approval; null while pending.
  approvedQty       Float?
  approvedUnitPrice Float?
  // Staff dropped this requested line at approval (kept for the diff).
  removed           Boolean @default(false)

  sortOrder Int @default(0)

  @@index([requestId])
  @@index([productId])
}

// Invite-only onboarding: staff enable a Customer for the portal and mint a
// tokenized invite; the buyer accepts it to create their BUYER login.
model PortalInvite {
  id         String @id @default(cuid())
  companyId  String
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  email String
  token String @unique

  invitedById String?
  invitedBy   User?   @relation("InviteInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  expires    DateTime
  acceptedAt DateTime?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([customerId])
}
