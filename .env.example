# --- Neon Postgres ---------------------------------------------------------
# Pooled connection (app runtime). From the Neon dashboard, "Pooled connection".
# Keep sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Direct connection (Prisma Migrate). Same string WITHOUT `-pooler` in the host.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# --- Auth.js ---------------------------------------------------------------
# Generate one with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_TRUST_HOST=true
